# Per-developer overrides. Copy to .env to use.
# Loaded by scripts/game.gd at startup.
#
# Precedence: shell env > .env file > Game.texture_pack @export

# Active block-texture pack. Folder name under assets/textures/blocks/packs/.
# Available out of the box: alpha_vanilla, pixel_perfection, programmer_art
MC_CLONE_TEXTURE_PACK=pixel_perfection

# Debug mode default. Accepts: 1/true/yes/on (any case) → enabled; anything
# else → disabled. The backtick key still toggles at runtime.
MC_CLONE_DEBUG_MODE=false

# Window resolution override. Accepts WIDTHxHEIGHT (e.g. 2560x1440) or
# 'fullscreen'. Default in project.godot is 1920x1080; leave unset to use it.
MC_CLONE_RESOLUTION=
