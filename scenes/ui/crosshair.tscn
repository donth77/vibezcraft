[node name="Crosshair" type="CanvasLayer"]

; Vanilla Alpha crosshair (nl.java:62-66):
;   glBindTexture("/gui/icons.png")
;   glEnable(GL_BLEND); glBlendFunc(GL_ONE_MINUS_DST_COLOR, GL_ONE_MINUS_SRC_COLOR)
;   drawTexturedModalRect(w/2 - 7, h/2 - 7, 0, 0, 16, 16)
;
; → blits the top-left 16×16 tile of icons.png with framebuffer inversion.
; The sprite has a 9×9 white "+" centered in the 16×16 tile, so arms land
; 27×3 px at GUI scale 3. We reproduce the blend in shaders/crosshair.gdshader
; (Godot has no GL_ONE_MINUS_DST_COLOR preset), and scale the 16×16 sprite by
; 3 to match vanilla GUI scale on 1080p. BackBufferCopy ensures SCREEN_TEXTURE
; is populated before the shader samples it.
[node name="Plus" type="Control" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
mouse_filter = 2

[node name="Copy" type="BackBufferCopy" parent="Plus"]
